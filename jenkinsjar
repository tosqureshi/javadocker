pipeline {
    agent {
      label 'mylinux'
    }

    stages {
        stage('installation maven') {
            steps {
               sh 'sudo dnf install maven -y'
            }
        }
     stage('creation of package') {
            steps {
             sh 'mvn clean package'
            }
        }
     stage('releasing pacakge') {
            steps {
             archiveArtifacts artifacts: 'target/*.jar', followSymlinks: false
            // mail bcc: '', body: 'Check', cc: '', from: '', replyTo: '', subject: 'Pipeline Notification', to: 'tosifq1809@gmail.com'
            }
        }
        stage('Install sonarqube cli') {
            steps {
            // Step to install SonarQube CLI
            sh 'sudo wget -O sonar-scanner.zip https://binaries.sonarsource.com/Distribution/sonar-scanner-cli/sonar-scanner-cli-5.0.1.3006-linux.zip'
            sh 'sudo unzip -o -q sonar-scanner.zip'
            sh 'sudo rm -rf /opt/sonar-scanner'
            sh 'sudo mv --force sonar-scanner-5.0.1.3006-linux /opt/sonar-scanner'
            sh 'sudo sh -c \'echo "#/bin/bash \nexport PATH=\\\"$PATH:/opt/sonar-scanner/bin\\\"" >/etc/profile.d/sonar-scanner.sh\''
            sh 'sudo chmod +x /opt/sonar-scanner/bin/sonar-scanner'
            sh '. /etc/profile.d/sonar-scanner.sh'
            }
        }
        stage('Analyzing Code Quality') {
            steps {
            // Step to analyze code quality with SonarQube
            sh '/opt/sonar-scanner/bin/sonar-scanner -Dsonar.projectKey=sonartest123tosif_mytestproject -Dsonar.organization=sonartest123tosif -Dsonar.qualitygate.wait=false -Dsonar.qualitygate.timeout=300 -Dsonar.sources=src/main/java/ -Dsonar.java.binaries=target/classes -Dsonar.host.url=https://sonarcloud.io -Dsonar.login=73512ce157187dd3405e670c4890ec6552af5011'
            }
        }
    }
}
