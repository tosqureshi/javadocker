pipeline {
    agent any

    stages {
        stage('install maven') {
            steps {
               sh 'sudo dnf install maven -y'
            }
        }
     stage('creation of package') {
            steps {
             sh 'mvn clean package'
            }
        }
     stage('releasing pacakge') {
            steps {
             archiveArtifacts artifacts: 'target/*.jar', followSymlinks: false
            mail bcc: '', body: 'Check', cc: '', from: '', replyTo: '', subject: 'Pipeline Notification', to: 'tosifq1809@gmail.com'
            }
        }
    }
}
